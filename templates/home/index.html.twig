{% extends 'base.html.twig' %}

{% block title %}Hello HomeController!{% endblock %}

{% block body %}
<div class="search"></div>
<div class="game-list">
    {% for game in games %}
        <div class="game-card">
            <div class="game-info">
                <div class="up-info">
                    <div class="game-title">
                        {{ game.title }}
                    </div>
                    <div class="favorite">
                        <img src="https://placehold.co/400/orange/white" alt="">
                    </div>
                </div>
                <div class="down-info">
                    <div class="notation">

                    </div>
                    <div class="platform">

                    </div>
                </div>
            </div>
            <div class="game-picture">
                <img src={{ game.imageOfTheBox }} alt="">
            </div>
        </div>
    {% else %}
        <tr>
            <td colspan="11">no records found</td>
        </tr>
    {% endfor %}
</div>
{% endblock %}
